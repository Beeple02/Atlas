# Atlas Environment Variables
# Copy this to .env for local dev, or set in Railway dashboard for production.
# NEVER commit a filled-in version of this file.

# ── Required ──────────────────────────────────────────────────────────────────
NER_API_KEY=your_ner_api_key_here

# ── Recommended ───────────────────────────────────────────────────────────────
# Must match the secret set in NER API Management webhook config
ATLAS_WEBHOOK_SECRET=choose_a_strong_random_secret

# ── Optional (defaults shown) ─────────────────────────────────────────────────
ATLAS_PORT=8000
ATLAS_LOG_LEVEL=INFO
ATLAS_DB_PATH=/data/atlas.db          # Use a Railway Volume mount path

NER_BASE_URL=http://150.230.117.88:8082

# Polling intervals in seconds
POLL_SECURITIES_INTERVAL=300          # 5 min
POLL_ORDERBOOK_INTERVAL=60            # 1 min (webhook is primary; this is fallback)
POLL_PRICE_HISTORY_INTERVAL=900       # 15 min
POLL_OHLCV_INTERVAL=900               # 15 min
POLL_SHAREHOLDERS_INTERVAL=600        # 10 min
POLL_STATS_INTERVAL=600               # 10 min

STAGGER_DELAY=15                      # Seconds between per-ticker polls
PRICE_HISTORY_DAYS=90                 # How far back to fetch history
NER_REQUEST_TIMEOUT=10                # Seconds before NER API call times out
